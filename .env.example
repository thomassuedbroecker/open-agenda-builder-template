# Open Event Agenda Builder - Environment Configuration Template
# Copy this file to .env and adjust values as needed

# Application Settings
APP_NAME="Open Event Agenda Builder"
APP_VERSION="1.1.0"
APP_DESCRIPTION="Build personal agendas from a configurable event schedule using only open-source tooling."
DEBUG=false

# Server Configuration
HOST=0.0.0.0
PORT=8082

# Event Configuration
EVENT_NAME="Sample Event Program"
EVENT_DAY_LABEL="Program Day"
EVENT_DATE="2026-04-15"
EVENT_TIMEZONE="Europe/Berlin"
AGENDA_LABEL="My Agenda"

# Schedule Source
SCHEDULE_FILE="app/data/sample-sessions.json"
TRACK_FILTER=""
START_TIME="09:00"
END_TIME="18:00"
DATA_SOURCE_NAME="Bundled JSON schedule"

# Cookie Settings
AGENDA_COOKIE_NAME="agenda_state"
AGENDA_COOKIE_SESSION_ONLY=true
AGENDA_COOKIE_MAX_AGE_SECONDS=604800
SECURE_COOKIE=false

# Cache Settings
CACHE_TTL_SECONDS=3600

# Notes:
# - The supported default schedule source is a local JSON file
# - The application does not require external SaaS services
# - For HTTPS deployments, set SECURE_COOKIE=true
# - Never commit real secrets or deployment-specific credentials
